# ==============================================================================
# loadtest-api-bench 環境変数テンプレート
# ==============================================================================
# このファイルをコピーして .env を作成してください:
#   cp .env.example .env
#
# pydantic-settings が APP_ プレフィックスの環境変数を自動で読み込みます。
# ==============================================================================

# --- DB 選択 ---
# 使用するデータベースバックエンドを指定
# 値: sqlite / cloud_sql / spanner / bigquery
APP_DB_TYPE=sqlite

# --- SQLite 設定 ---
# SQLite のデータベースファイルパス
# ":memory:" でインメモリ DB (テスト用)
APP_SQLITE_PATH=:memory:

# --- Cloud SQL (PostgreSQL) 設定 ---
# asyncpg を使った非同期接続の DSN
# ローカル開発: postgresql+asyncpg://user:password@localhost:5432/dbname
# Cloud Run:    postgresql+asyncpg://user:password@/dbname?host=/cloudsql/project:region:instance
APP_CLOUD_SQL_DSN=

# --- Cloud Spanner 設定 ---
# GCP プロジェクト ID
APP_SPANNER_PROJECT=
# Spanner インスタンス名
APP_SPANNER_INSTANCE=
# Spanner データベース名
APP_SPANNER_DATABASE=

# --- BigQuery 設定 ---
# GCP プロジェクト ID
APP_BIGQUERY_PROJECT=
# BigQuery データセット名
APP_BIGQUERY_DATASET=

# --- コネクションプール設定 (Cloud SQL 用) ---
# プールに保持する常時接続数
APP_POOL_SIZE=5
# pool_size を超えた場合に追加で作成できる接続数
APP_MAX_OVERFLOW=10
# プールから接続を取得する際のタイムアウト (秒)
APP_POOL_TIMEOUT=30

# --- ログ設定 ---
# ログ出力フォーマット
# text: 人間が読みやすい形式 (ローカル開発用)
# json: 構造化 JSON ログ (Cloud Run 用、Cloud Logging と連携)
APP_LOG_FORMAT=text

# ==============================================================================
# デプロイ用設定 (deploy.sh で使用)
# deploy.sh は必須の環境変数が未設定の場合エラーで停止します。
# ==============================================================================

# GCP プロジェクト ID (必須)
GCP_PROJECT_ID=your-gcp-project-id

# Cloud Run デプロイリージョン (省略時: asia-northeast1)
GCP_REGION=asia-northeast1

# Cloud SQL インスタンス接続名 (cloud_sql デプロイ時は必須)
# 形式: project:region:instance
CLOUD_SQL_INSTANCE_CONNECTION=your-project:asia-northeast1:your-instance
